{
  "name": "neon-gather-bkk",
  "version": "0.1.0",
  "private": true,
  "description": "Neon Gather BKK — cozy multiplayer community-mall web game (Phase 0 MVP)",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "infra:up": "docker compose up -d postgres redis minio minio-init",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v",
    "stack:up": "docker compose --profile apps up -d --build",
    "stack:down": "docker compose --profile apps down",
    "api:dev": "cd apps/api && go run . ",
    "api:seed": "cd apps/api && go run . seed",
    "api:build": "cd apps/api && go build -o bin/api .",
    "api:test": "cd apps/api && go test ./...",
    "setup": "pnpm install && pnpm infra:up && node ./scripts/dev-setup.mjs"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3"
  }
}
