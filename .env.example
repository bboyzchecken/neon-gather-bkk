# ============================================================
# Neon Gather BKK — root environment (dev)
# Copy to `.env` (already provided with dev defaults). These
# values are LOCAL DEV ONLY — never reuse in production.
# ============================================================

ENV=development
API_PORT=5001
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- JWT (HS256) ---
JWT_SECRET_KEY=change_me
JWT_TTL_HOURS=168

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=neon
POSTGRES_PASSWORD=neon_dev_pw
POSTGRES_DB=neon_gather

# --- Redis (leaderboard / sessions) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Object storage (MinIO dev / Cloudflare R2 prod) via AWS SDK v2 ---
R2_ENDPOINT=http://localhost:9000
R2_REGION=us-east-1
R2_ACCESS_KEY=neon_minio
R2_SECRET_KEY=neon_minio_pw
R2_IMAGE_BUCKET=neon-assets
R2_PUBLIC_URL=http://localhost:9000/neon-assets

# --- Economy tuning (server-authoritative) ---
SIGNUP_BONUS_COINS=1000
GUEST_BONUS_COINS=250

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_GAME_URL=http://localhost:5173

# --- Game (Vite) ---
VITE_API_URL=http://localhost:5000

# --- BFL (asset generation, scripts/gen-assets.mjs) ---
# Get a key at https://api.bfl.ai — NEVER commit the real key.
BFL_API_KEY=your_bfl_key_here
